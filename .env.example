# Required: OpenRouter API key for LLM access
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Required for webhook endpoints: Bearer token for authenticating incoming requests
MODAL_BEARER_TOKEN=your-secret-token-here

# Optional: Modal deployment tokens (usually set via `modal token set`)
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
