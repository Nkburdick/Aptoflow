<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Car Scout Digest — {{ date_short }}</title>
</head>
<body style="margin:0;padding:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;background:#f5f5f5;color:#1a1a1a;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f5f5f5;">
<tr>
<td align="center" style="padding:24px 12px;">

<!-- Container -->
<table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="background:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.06);">

<!-- Header -->
<tr>
<td style="padding:24px 24px 8px 24px;border-bottom:1px solid #eee;">
<div style="font-size:20px;font-weight:700;">🚗 Car Scout Digest</div>
<div style="font-size:13px;color:#666;margin-top:4px;">{{ date_long }} · {{ summary_line }}</div>
</td>
</tr>

{% if top_picks %}
<!-- Top Picks -->
<tr><td style="padding:20px 24px 8px 24px;">
<div style="font-size:16px;font-weight:600;color:#b8860b;">🏆 Top Picks</div>
</td></tr>
{% for card in top_picks %}
<tr><td style="padding:8px 24px;">
{{ render_card(card, emphasize=True) }}
</td></tr>
{% endfor %}
{% endif %}

{% if new_today %}
<!-- New Today -->
<tr><td style="padding:20px 24px 8px 24px;">
<div style="font-size:16px;font-weight:600;color:#1a1a1a;">🆕 New Today ({{ new_today|length }})</div>
</td></tr>
{% for card in new_today %}
<tr><td style="padding:6px 24px;">
{{ render_card(card, emphasize=False) }}
</td></tr>
{% endfor %}
{% endif %}

{% if price_drops %}
<!-- Price Drops -->
<tr><td style="padding:20px 24px 8px 24px;">
<div style="font-size:16px;font-weight:600;color:#2e7d32;">📉 Price Drops ({{ price_drops|length }})</div>
</td></tr>
{% for card in price_drops %}
<tr><td style="padding:6px 24px;">
{{ render_card(card, emphasize=False, show_old_price=True) }}
</td></tr>
{% endfor %}
{% endif %}

{% if empty %}
<tr><td style="padding:32px 24px;text-align:center;color:#666;">
<div style="font-size:15px;">No new matches in the last 24h.</div>
<div style="font-size:12px;margin-top:8px;">Still watching — {{ sources_checked }} sources, {{ listings_in_state }} listings tracked.</div>
</td></tr>
{% endif %}

<!-- Footer -->
<tr><td style="padding:20px 24px;border-top:1px solid #eee;font-size:11px;color:#888;">
Last scout: {{ last_scout_local }} · Sources: {{ sources_checked }} · Listings in state: {{ listings_in_state }}
</td></tr>

</table>
</td>
</tr>
</table>
</body>
</html>
