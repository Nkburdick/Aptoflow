# ─── LLM ───────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# ─── MarketCheck API (digest source) ──────────────────────────────────────
# Free tier: 500 calls/month. 7 (make, model) buckets × 2 runs/day = 14/day
# = ~420/month. Fits the free cap.
MARKETCHECK_API_KEY=

# ─── Email delivery (daily digest) ────────────────────────────────────────
APTOFLOW_SMTP_HOST=smtp.gmail.com
APTOFLOW_SMTP_PORT=587
APTOFLOW_SMTP_USERNAME=alfred@aptoworks.com
APTOFLOW_SMTP_PASSWORD=
CAR_SCOUT_DIGEST_FROM=alfred@aptoworks.com
CAR_SCOUT_DIGEST_TO=nick@aptoworks.com

# ─── Pennyworth (unicorn SMS ping) ────────────────────────────────────────
# Uses the same AOL_API_TOKEN Pennyworth uses for all authenticated API calls.
PENNYWORTH_BASE_URL=https://pw.aptoworks.cloud
AOL_API_TOKEN=

# ─── VIN history (Tier B, optional — on-demand for unicorn candidates) ────
# Pick one provider; pricing varies.
VIN_HISTORY_PROVIDER=vinaudit
VINAUDIT_API_KEY=

# ─── Scraping fallback (optional — Bright Data proxy for anti-bot) ────────
BRIGHTDATA_ZONE=
BRIGHTDATA_PASSWORD=

# ─── Search parameters ────────────────────────────────────────────────────
SCOUT_ZIP=98225
SCOUT_RADIUS_MI=100
BUDGET_CEILING_USD=22000
YEAR_FLOOR=2015
PRIMARY_MILEAGE_CEILING=80000
SECONDARY_MILEAGE_CEILING=110000

# ─── Unicorn / rate-limit safety ──────────────────────────────────────────
UNICORN_SMS_DAILY_CAP=3

# ─── State persistence ────────────────────────────────────────────────────
STATE_FILE_PATH=/data/car_scout_state.json
